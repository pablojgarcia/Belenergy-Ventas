# ⚠️ Copiar este archivo a .env y completar los valores.
#    NUNCA committear el .env al repositorio.
#    En Railway/usar el panel de Environment Secrets (cifrados en reposo y transito).
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/authdb
JWT_SECRET=genera-uno-con-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:8000,https://tudominio.com
